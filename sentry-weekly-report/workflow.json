      "parameters": {
        "jsCode": "const issues = $input.first().json.data;\nconst runDate = new Date().toISOString().split('T')[0];\n\nconst slimmed = issues.slice(0, 40).map(issue => ({\n  run_date: runDate,\n  issue_id: issue.shortId,\n  title: issue.title,\n  events: issue.count,\n  users: issue.userCount,\n  first_seen: issue.firstSeen,\n  last_seen: issue.lastSeen\n}));\n\nreturn slimmed.map(item => ({ json: item }));"
